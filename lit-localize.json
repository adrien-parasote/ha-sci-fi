{
  "$schema": "https://raw.githubusercontent.com/lit/lit/main/packages/localize-tools/config.schema.json",
  "sourceLocale": "en",
  "targetLocales": [
    "fr"
  ],
  "inputFiles": [
    "src/*.ts",
    "src/**/*.ts",
    "src/**/**/*.ts",
    "src/**/**/**/*.ts",
    "src/**/**/**/**/*.ts"
  ],
  "output": {
    "mode": "runtime",
    "outputDir": "./src/locales/locales",
    "localeCodesModule": "./src/locales/locale-codes.ts"
  },
  "interchange": {
    "format": "xliff",
    "xliffDir": "./xliff/"
  }
}
